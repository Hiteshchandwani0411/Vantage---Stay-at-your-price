<%- layout("/layouts/boilerplate") %>

<style>
  .error-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 2rem;
  }

  .error-card {
    text-align: center;
    max-width: 500px;
  }

  .error-icon {
    font-size: 4rem;
    color: #fe424d;
    margin-bottom: 1rem;
  }

  .error-card h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: #222222;
    margin-bottom: 0.5rem;
  }

  .error-card p {
    font-size: 1rem;
    color: #717171;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .error-btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    background-color: #fe424d;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .error-btn:hover {
    background-color: #e63840;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(254, 66, 77, 0.3);
  }
</style>

<div class="error-container">
  <div class="error-card">
    <div class="error-icon">
      <i class="fas fa-exclamation-triangle"></i>
    </div>
    <h1>Oops!</h1>
    <p><%= message %></p>
    <a href="/listings" class="error-btn">Back to Home</a>
  </div>
</div>
