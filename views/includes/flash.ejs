<% if (success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-left: 4px solid #198754; border-radius: 8px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);">
      <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
      <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if (error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-left: 4px solid #dc3545; border-radius: 8px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);">
      <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i>
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>