<% layout("/layouts/boilerplate") %>

<style>
  .auth-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 2rem;
  }

  .auth-card {
    width: 100%;
    max-width: 420px;
    padding: 3rem 2.5rem;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border: 1px solid #e0e0e0;
  }

  .auth-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .auth-header h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #222222;
    margin-bottom: 0.5rem;
  }

  .auth-header p {
    color: #717171;
    font-size: 0.95rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-weight: 600;
    color: #222222;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .form-control {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 1.5px solid #d0d0d0;
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .form-control:focus {
    outline: none;
    border-color: #fe424d;
    box-shadow: 0 0 0 3px rgba(254, 66, 77, 0.1);
  }

  .form-control::placeholder {
    color: #b0b0b0;
  }

  .submit-btn {
    width: 100%;
    padding: 0.95rem;
    background-color: #fe424d;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 0.5rem;
  }

  .submit-btn:hover {
    background-color: #e63840;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(254, 66, 77, 0.3);
  }

  .auth-footer {
    text-align: center;
    margin-top: 1.5rem;
    color: #717171;
    font-size: 0.9rem;
  }

  .auth-footer a {
    color: #fe424d;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }
</style>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Welcome Back</h1>
      <p>Sign in to your Vantage account</p>
    </div>

    <form action="/login" method="post" class="needs-validation" novalidate>
      <div class="form-group">
        <label for="username" class="form-label">
          <i class="fas fa-user" style="color: #fe424d; margin-right: 0.5rem;"></i>
          Username
        </label>
        <input
          type="text"
          id="username"
          name="username"
          class="form-control"
          placeholder="Enter your username"
          required
        />
      </div>

      <div class="form-group">
        <label for="password" class="form-label">
          <i class="fas fa-lock" style="color: #fe424d; margin-right: 0.5rem;"></i>
          Password
        </label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Enter your password"
          class="form-control"
          required
        />
      </div>

      <button type="submit" class="submit-btn">Sign In</button>
    </form>

    <div class="auth-footer">
      Don't have an account? <a href="/signup">Register here</a>
    </div>
  </div>
</div>
