<% layout("/layouts/boilerplate") %>

  <body>
    <div class="row">
      <div class="col-8 offset-3">
        <h3><b>
            <%= listing.title %>
          </b></h3>
      </div>

      <div class="card col-6 offset-3">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" />
        <div class="card-body">
          <p class="card-text"> Owned By <i><%= listing.owner.username %></i></p>
          <p class="card-text">
            <%= listing.description %>
              <br />
              &#8377; <%= listing.price.toLocaleString("en-IN") %>
                <br />
                <%= listing.location %>
                  <br />
                  <%= listing.country %>
          </p>
        </div>

        <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="show-btns mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn red-btn">Edit</a><br />
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
              <button type="submit" class="btn btn-dark">Delete listing</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
    <div class="row">
      <div class="col-6 offset-3">
        <hr />
        <% if (currUser) { %>
          <h3>Leave a Review</h3>
          <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
            <div class="mt-3">
              <fieldset class="starability-grow">
                <legend>Rating</legend>
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
  
            <div class="mt-3">
              <label for="comment" class="form-label">Comment</label>
              <textarea type="text" rows="5" cols="30" name="review[comment]" class="form-control" required></textarea>
              <div class="invalid-feedback">Please add some comments for review.</div>
            </div>
  
            <button class="btn btn-outline-dark mt-3">Submit</button>
          </form>
          <hr />
        <% } %>

        <% if (listing.reviews.length) { %>
          <div class="row mt-3">
            <p><b>All Reviews</b></p>
            <% for(const review of listing.reviews) { %>
              <div class="card col-5 ms-3 mb-3 pt-2">
                <div class="card-body">
                  <h5 class="card-title">@<%= review.author.username %></h5>
                  <p class="starability-result" data-rating="<%= review.rating %>">
                    Rated: <%= review.rating %> stars
                  </p>
                  <p class="card-text">
                    <%= review.comment %>
                  </p>
  
                  <form class="mb-3" method="POST"
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                </div>
              </div>
              <% } %>
          </div>
        <% } %>
        <h3>Where you'll be</h3>
        <div id="map"></div>
      </div>
    </div>

    <script>
      // 1. EJS variable se coordinates ko frontend JavaScript mein pass karein
      // Dhyan de: MapTiler/Mongo mein [Lng, Lat] hota hai, Leaflet ko [Lat, Lng] chahiye
      const coordinates = JSON.parse('<%= JSON.stringify(listing.geometry.coordinates) %>');
      const lat = coordinates[1];
      const lng = coordinates[0];

      // 2. Leaflet Map Initialize karein
      const map = L.map('map').setView([lat, lng], 14);

      // 3. OpenStreetMap ke free tiles add karein (Bina kisi Token ke chalega)
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);

      // 4. Map par point/marker lagayein
      L.marker([lat, lng])
        .addTo(map)
        .bindPopup(`<b><%= listing.title %></b><p><%= listing.location %></p>`)
        .openPopup();
    </script>
  </body>