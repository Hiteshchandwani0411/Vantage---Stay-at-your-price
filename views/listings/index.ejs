<% layout("/layouts/boilerplate") %>

<style>
    .listings-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e0e0e0;
    }

    .listings-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #222222;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .listings-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        padding: 1rem 0;
    }

    @media (max-width: 1200px) {
        .listings-container {
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1.8rem;
        }
    }

    @media (max-width: 768px) {
        .listings-container {
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .listings-container {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .listings-header h1 {
            font-size: 1.8rem;
        }
    }

    .listing-card {
        text-decoration: none;
        color: inherit;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .listing-card:hover {
        transform: translateY(-8px);
    }

    .listing-image-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        margin-bottom: 1rem;
        aspect-ratio: 1;
        background-color: #f0f0f0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .listing-card:hover .listing-image-wrapper {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    .listing-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .listing-card:hover .listing-image {
        transform: scale(1.05);
    }

    .image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0);
        transition: background 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .listing-card:hover .image-overlay {
        background: rgba(0, 0, 0, 0.1);
    }

    .listing-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background-color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        z-index: 2;
    }

    .save-btn {
        position: absolute;
        top: 12px;
        left: 12px;
        background-color: rgba(255, 255, 255, 0.8);
        border: none;
        border-radius: 8px;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        z-index: 2;
    }

    .save-btn:hover {
        background-color: white;
        transform: scale(1.1);
    }

    .listing-info {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .listing-title {
        font-size: 1rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.5rem;
        line-height: 1.4;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .listing-location {
        font-size: 0.875rem;
        color: #717171;
        margin-bottom: 0.75rem;
    }

    .listing-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
    }

    .listing-rating {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.875rem;
        color: #222222;
    }

    .listing-rating .star {
        color: #ffb500;
    }

    .listing-rating .review-count {
        color: #717171;
        margin-left: 0.25rem;
    }

    .listing-price {
        font-size: 1rem;
        font-weight: 600;
        color: #222222;
        text-align: right;
    }

    .price-label {
        font-size: 0.75rem;
        color: #717171;
        font-weight: 400;
    }

    .no-listings {
        text-align: center;
        padding: 3rem 0;
        color: #717171;
    }

    .no-listings h2 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }
</style>

<div class="listings-page">
    <div class="listings-header">
        <h1>Explore Homes</h1>
    </div>

    <% if (allListings.length > 0) { %>
        <div class="listings-container">
            <% for (const listing of allListings) { %>
                <a href="/listings/<%= listing._id %>" class="listing-card">
                    <div class="listing-image-wrapper">
                        <img 
                            src="<%= listing.image.url %>" 
                            onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1773062177647-76cf543b1795?q=80&w=1470&auto=format&fit=crop';" 
                            class="listing-image" 
                            alt="<%= listing.title %>"
                        >
                        <div class="image-overlay"></div>
                        
                        <% if (listing.reviews && listing.reviews.length > 0) { %>
                            <div class="listing-badge">
                                <i class="fas fa-star" style="color: #ffb500; margin-right: 4px;"></i>
                                <span style="font-weight: 700;"><%= (listing.reviews.reduce((sum, r) => sum + r.rating, 0) / listing.reviews.length).toFixed(2) %></span>
                            </div>
                        <% } %>
                        
                        <button class="save-btn" onclick="event.preventDefault(); alert('Added to wishlist!');">
                            <i class="far fa-heart" style="font-size: 1.2rem; color: #222222;"></i>
                        </button>
                    </div>

                    <div class="listing-info">
                        <h3 class="listing-title"><%= listing.title %></h3>
                        
                        <p class="listing-location">
                            <i class="fas fa-map-marker-alt" style="color: #fe424d; margin-right: 0.5rem;"></i>
                            <%= listing.location %>
                        </p>

                        <div class="listing-footer">
                            <div class="listing-rating">
                                <% if (listing.reviews && listing.reviews.length > 0) { %>
                                    <i class="fas fa-star star"></i>
                                    <span style="margin-left: 0.25rem;">(<span class="review-count"><%= listing.reviews.length %></span>)</span>
                                <% } else { %>
                                    <span style="color: #717171; font-size: 0.875rem;">New</span>
                                <% } %>
                            </div>
                            <div class="listing-price">
                                &#8377; <strong><%= listing.price.toLocaleString("en-IN") %></strong>
                                <div class="price-label">/ night</div>
                            </div>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    <% } else { %>
        <div class="no-listings">
            <h2>No listings found</h2>
            <p>Check back soon for amazing homes!</p>
        </div>
    <% } %>
</div>